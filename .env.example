# Web3Forms access key — required for the contact form to submit
# Get a free key at https://web3forms.com (enter your email, key is emailed instantly)
# For local development: copy this file to .env and fill in your key
# For GitHub Pages CI: add PUBLIC_WEB3FORMS_KEY as a repository secret (Settings → Secrets → Actions)
#   then pass it to the build step in .github/workflows/deploy.yml:
#     env:
#       PUBLIC_WEB3FORMS_KEY: ${{ secrets.PUBLIC_WEB3FORMS_KEY }}
PUBLIC_WEB3FORMS_KEY=
