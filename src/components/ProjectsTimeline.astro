---
import { getCollection } from 'astro:content';
import { shortDateLabel, isOngoing } from '../lib/duration';

const allProjects = await getCollection('projects');
const projects = allProjects.sort(
  (a, b) => a.data.startDate.getTime() - b.data.startDate.getTime()
);
---

<div class="relative flex flex-col gap-0" aria-label="Projects timeline" role="list">
  <!-- Vertical rule: starts at first dot (top-2), continues past last dot (bottom-0) -->
  <div class="absolute left-[7px] top-2 bottom-0 w-px bg-border" aria-hidden="true"></div>

  {projects.map((p) => {
    const ongoing = isOngoing(p.data.endDate);
    return (
      <div class="relative flex gap-6 pb-10 group" role="listitem">
        <div
          aria-hidden="true"
          class="mt-1.5 w-4 h-4 shrink-0 rounded-full border-2 border-border bg-bg group-hover:border-accent group-hover:bg-accent transition-colors duration-200"
        ></div>
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase text-text-muted mb-1">
            {shortDateLabel(p.data.startDate)}{ongoing && ' — Ongoing'}
          </p>
          <div class="flex items-center gap-3 flex-wrap">
            <a
              href={`/projects/${p.id}/`}
              class="text-base font-semibold text-text hover:text-accent transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-sm"
              aria-label={`${p.data.title} · ${shortDateLabel(p.data.startDate)}${ongoing ? ' — Ongoing' : ''} · ${p.data.status}`}
            >
              {p.data.title}
            </a>
            {p.data.status === 'shipped' && (
              <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300">Shipped</span>
            )}
            {p.data.status === 'in-progress' && (
              <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300">In Progress</span>
            )}
            {p.data.status === 'planned' && (
              <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300">Planned</span>
            )}
            {p.data.status === 'archived' && (
              <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400">Archived</span>
            )}
          </div>
        </div>
      </div>
    );
  })}
</div>
