---
import { getCollection } from 'astro:content';
import { monthLabel } from '../lib/duration';

const allProjects = await getCollection('projects');
const projects = allProjects.sort(
  (a, b) => a.data.startDate.getTime() - b.data.startDate.getTime()
);
---

<div class="relative pl-6 border-l-2 border-accent space-y-8">
  {projects.map((p) => (
    <div class="relative">
      <span class="absolute -left-5.75 top-1 w-3 h-3 rounded-full bg-accent ring-2 ring-bg"></span>
      <span class="text-xs font-mono text-text-muted tracking-wide">
        {monthLabel(p.data.startDate)}
      </span>
    </div>
  ))}
</div>
