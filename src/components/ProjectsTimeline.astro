---
import { getCollection } from 'astro:content';
import { monthLabel, isOngoing } from '../lib/duration';

const allProjects = await getCollection('projects');
const projects = allProjects.sort(
  (a, b) => a.data.startDate.getTime() - b.data.startDate.getTime()
);

// Group projects by year for section dividers
const byYear = projects.reduce<Record<number, typeof projects>>((acc, p) => {
  const year = p.data.startDate.getFullYear();
  (acc[year] ??= []).push(p);
  return acc;
}, {});
const years = Object.keys(byYear).map(Number).sort((a, b) => a - b);
---

<div class="relative pl-6 border-l-2 border-accent space-y-10">
  {years.map((year) => (
    <div>
      <div class="relative mb-6">
        <span class="absolute -left-13 top-0.5 text-xs font-semibold tracking-widest uppercase text-accent select-none">
          {year}
        </span>
      </div>
      <div class="space-y-8">
        {byYear[year].map((p) => (
          <div class="relative">
            {isOngoing(p.data.endDate) ? (
              <span class="absolute -left-5.75 top-1 w-3 h-3 rounded-full bg-accent ring-2 ring-bg animate-pulse"></span>
            ) : (
              <span class="absolute -left-5.75 top-1 w-3 h-3 rounded-full bg-accent ring-2 ring-bg"></span>
            )}
            <span class="text-xs font-mono text-text-muted tracking-wide">
              {monthLabel(p.data.startDate)}{isOngoing(p.data.endDate) && ' — Ongoing'}
            </span>
            <div class="flex items-center gap-3 mt-1 flex-wrap">
              <a
                href={`/projects/${p.id}/`}
                class="text-base font-semibold text-text hover:text-accent transition-colors"
              >
                {p.data.title}
              </a>
              {p.data.status === 'shipped' && (
                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300">Shipped</span>
              )}
              {p.data.status === 'in-progress' && (
                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300">In Progress</span>
              )}
              {p.data.status === 'planned' && (
                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300">Planned</span>
              )}
              {p.data.status === 'archived' && (
                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400">Archived</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}
</div>
