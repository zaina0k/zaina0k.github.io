---
// Copy updated manually each month — no props needed
---

<section class="bg-[var(--color-bg-subtle)]">
  <div class="mx-auto max-w-5xl px-6 py-16">

    <!-- Section header -->
    <div class="flex items-baseline justify-between mb-10">
      <div class="flex items-baseline gap-4">
        <span class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)]">01 / Now</span>
        <h2 class="text-2xl font-semibold tracking-tight text-[var(--color-text)]">Currently</h2>
      </div>
      <span class="text-xs text-[var(--color-text-muted)] tracking-wide hidden sm:block">Updated Jun 2026</span>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Building -->
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 flex flex-col gap-3">
        <span class="text-[10px] font-bold tracking-widest uppercase text-[var(--color-accent)]">Building</span>
        <p class="text-sm font-medium text-[var(--color-text)]">Rebuilding my portfolio</p>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          Migrating from Jekyll to Astro with a custom design system. You're looking at it.
        </p>
      </div>

      <!-- Reading -->
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 flex flex-col gap-3">
        <span class="text-[10px] font-bold tracking-widest uppercase text-[var(--color-accent)]">Reading</span>
        <p class="text-sm font-medium text-[var(--color-text)]">The Pragmatic Programmer</p>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          By Andy Hunt and Dave Thomas. Working through timeless advice on writing better software and growing as a developer.
        </p>
      </div>

      <!-- Prepping -->
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 flex flex-col gap-3">
        <span class="text-[10px] font-bold tracking-widest uppercase text-[var(--color-accent)]">Prepping</span>
        <p class="text-sm font-medium text-[var(--color-text)]">Interview preparation</p>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          LeetCoding and practising interview questions to sharpen problem-solving and get ready for roles.
        </p>
      </div>

    </div>
  </div>
</section>
