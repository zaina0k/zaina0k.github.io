---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  year: string;
  summary: string;
  tags: string[];
  href: string;
  thumbnail?: ImageMetadata;
}

const { title, year, summary, tags, href, thumbnail } = Astro.props;
const thumbnailAlt = `Screenshot of ${title}`;
---

<a
  href={href}
  class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)] hover:ring-2 hover:ring-[var(--color-accent)] hover:scale-[1.02] transition-all duration-200 overflow-hidden"
>
  <!-- Image area with title overlay -->
  <div class="relative aspect-video w-full overflow-hidden">
    {thumbnail ? (
      <Image
        src={thumbnail}
        alt={thumbnailAlt}
        width={800}
        height={450}
        loading="lazy"
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="w-full h-full bg-[var(--color-accent)] opacity-20" />
    )}

    <!-- Accent banner behind title -->
    <div class="absolute inset-x-0 bottom-0 bg-[var(--color-accent)]/90 px-4 py-3 z-10">
      <h3 class="text-sm font-semibold text-white leading-snug group-hover:text-white/80 group-focus-visible:text-white/80 transition-colors">
        {title}
      </h3>
    </div>
  </div>

  <!-- Below-image strip -->
  <div class="p-4">
    <!-- Year -->
    <p class="text-xs text-[var(--color-text-muted)] tracking-wide mb-2">{year}</p>

    <!-- Summary -->
    <p class="text-sm text-[var(--color-text)] leading-relaxed mb-4">{summary}</p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-[10px] font-semibold tracking-widest uppercase px-2 py-1 rounded bg-[var(--color-bg-subtle)] border border-[var(--color-border)] text-[var(--color-text-muted)]">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
