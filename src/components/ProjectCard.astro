---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  number: string;
  title: string;
  year: string;
  summary: string;
  detail: string;
  tags: string[];
  href: string;
  thumbnail?: ImageMetadata;
  duration: string;
}

const { number, title, year, summary, tags, href, thumbnail, duration } = Astro.props;
const thumbnailAlt = `Screenshot of ${title}`;
---

<a
  href={href}
  class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)] transition-colors overflow-hidden"
>
  <!-- Image area with overlaid number + title -->
  <div class="relative aspect-video w-full overflow-hidden">
    {thumbnail ? (
      <Image
        src={thumbnail}
        alt={thumbnailAlt}
        width={800}
        height={450}
        loading="lazy"
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="w-full h-full bg-[var(--color-accent)] flex items-center justify-center opacity-20">
        <span class="text-5xl font-bold tracking-widest text-[var(--color-bg)]">{number}</span>
      </div>
    )}

    <!-- Gradient scrim + overlay text (always visible) -->
    <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent pt-8 pb-3 px-4 z-10">
      <div class="flex items-baseline gap-2">
        <span class="text-xs font-bold tracking-widest text-[var(--color-accent)]">{number}</span>
        <h3 class="text-sm font-semibold text-white leading-snug group-hover:text-[var(--color-accent)] group-focus-visible:text-[var(--color-accent)] transition-colors">
          {title}
        </h3>
      </div>
    </div>

    <!-- Hover reveal panel (slides up from bottom) -->
    <div class="absolute inset-x-0 bottom-0 z-20 translate-y-full group-hover:-translate-y-0 group-focus-visible:-translate-y-0 transition-transform duration-300 ease-out bg-black/85 backdrop-blur-sm px-4 pt-4 pb-3">
      <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-accent)] mb-2">{duration}</p>
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="text-[10px] font-semibold tracking-widest uppercase px-2 py-0.5 rounded bg-white/10 text-white/80">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- Below-image strip -->
  <div class="p-4">
    <!-- Year -->
    <p class="text-xs text-[var(--color-text-muted)] tracking-wide mb-2">{year}</p>

    <!-- Summary -->
    <p class="text-sm text-[var(--color-text)] leading-relaxed mb-4">{summary}</p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-[10px] font-semibold tracking-widest uppercase px-2 py-1 rounded bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)]">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
