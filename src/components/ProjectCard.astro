---
import type { ImageMetadata } from 'astro';

interface Props {
  number: string;
  title: string;
  year: string;
  summary: string;
  detail: string;
  tags: string[];
  href: string;
  thumbnail?: ImageMetadata;
  duration: string;
}

const { number, title, year, summary, detail, tags, href, thumbnail, duration } = Astro.props;
---

<a
  href={href}
  class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 hover:border-[var(--color-accent)] transition-colors"
>
  <!-- Number + title row -->
  <div class="flex items-baseline gap-3 mb-1">
    <span class="text-xs font-bold tracking-widest text-[var(--color-accent)]">{number}</span>
    <h3 class="text-base font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
      {title}
    </h3>
  </div>

  <!-- Year -->
  <p class="text-xs text-[var(--color-text-muted)] tracking-wide mb-3">{year}</p>

  <!-- One-line summary -->
  <p class="text-sm font-medium text-[var(--color-text)] mb-2">{summary}</p>

  <!-- 2-line detail -->
  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-5">{detail}</p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="text-[10px] font-semibold tracking-widest uppercase px-2 py-1 rounded bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)]">
        {tag}
      </span>
    ))}
  </div>
</a>
