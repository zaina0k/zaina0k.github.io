---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="flex flex-col gap-0.5">
  <span class="text-2xl font-semibold tracking-tight text-[var(--color-text)]">{value}</span>
  <span class="text-[10px] font-semibold tracking-widest uppercase text-[var(--color-text-muted)]">{label}</span>
</div>
