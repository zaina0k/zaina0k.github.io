---
import { Image } from 'astro:assets';
import StatCard from './StatCard.astro';
import profileReal   from '../assets/profile real.png';
import profileSketch from '../assets/profile sketch.png';
---

<section class="mx-auto max-w-5xl px-6 py-16 md:py-24">
  <div class="flex flex-col md:flex-row md:items-start md:gap-16">

    <!-- Left: text content -->
    <div class="flex-1">
      <!-- Status line -->
      <div class="flex items-center gap-2 mb-8">
        <span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        <span class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)]">
          CS Graduate · Open to opportunities
        </span>
      </div>

      <!-- Stacked headline -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold leading-tight tracking-tight text-[var(--color-text)] mb-6">
        Engineer.<br />
        Problem solver.<br />
        <span class="text-[var(--color-accent)]">Builder.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-md mb-10">
        Full-stack software engineering with Python, JavaScript,
        and a bias towards shipping. University of Leicester CS graduate.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-wrap gap-3 mb-12">
        <a
          href="/projects/"
          class="inline-flex items-center px-5 py-2.5 rounded text-sm font-semibold bg-[var(--color-accent)] text-[var(--color-bg)] hover:bg-[var(--color-accent-hover)] transition-colors"
        >
          View Projects
        </a>
        <a
          href="/cv/"
          class="inline-flex items-center px-5 py-2.5 rounded text-sm font-semibold border border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
        >
          Download CV
        </a>
        <a
          href="https://github.com/zaina0k"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-5 py-2.5 rounded text-sm font-semibold border border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
        >
          GitHub ↗
        </a>
      </div>

      <!-- Stats strip -->
      <div class="flex flex-wrap gap-8 pt-8 border-t border-[var(--color-border)]">
        <StatCard value="4" label="Projects Shipped" />
        <StatCard value="2" label="Hackathons" />
        <StatCard value="7th/27" label="Morgan Stanley Challenge" />
      </div>
    </div>

    <!-- Right: profile photo (light = real photo, dark = sketch) -->
    <div class="shrink-0 order-first md:order-last mb-8 md:mb-0">
      <Image
        src={profileReal}
        alt="Zain Altaf"
        width={512}
        height={512}
        densities={[1, 2, 3]}
        class="w-48 h-48 md:w-64 md:h-64 rounded-xl object-cover border border-[var(--color-border)] dark:hidden"
      />
      <Image
        src={profileSketch}
        alt="Zain Altaf"
        width={512}
        height={512}
        densities={[1, 2, 3]}
        class="w-48 h-48 md:w-64 md:h-64 rounded-xl object-cover border border-[var(--color-border)] hidden dark:block"
      />
    </div>

  </div>
</section>
