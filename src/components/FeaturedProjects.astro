---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const allProjects = await getCollection('projects', ({ data }) => data.featured);
const projects = allProjects.sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<section class="mx-auto max-w-5xl px-6 py-16">

  <!-- Section header -->
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-10 gap-4">
    <div class="flex items-baseline gap-4">
      <span class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)]">02 / Projects</span>
      <h2 class="text-2xl font-semibold tracking-tight text-[var(--color-text)]">Selected Work</h2>
    </div>
    <a
      href="/projects/"
      class="text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
    >
      View all projects ↗
    </a>
  </div>

  <p class="text-[var(--color-text-muted)] mb-10 max-w-lg">
    Four projects that show how I think, build, and collaborate.
  </p>

  <!-- Cards grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {projects.map((project) => (
      <ProjectCard
        number={String(project.data.sortOrder).padStart(2, '0')}
        title={project.data.title}
        year={String(project.data.startDate.getFullYear())}
        summary={project.data.summary}
        detail={project.data.detail}
        tags={project.data.tags}
        href={`/projects/${project.id}/`}
      />
    ))}
  </div>

</section>
