---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FooterCTA from '../../components/FooterCTA.astro';
import { formatDateRange, formatDuration } from '../../lib/duration';
import MediaCarousel from '../../components/MediaCarousel';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);
const ogImage = data.ogImage ?? data.heroImage?.src ?? data.thumbnail?.src;
---

<BaseLayout title={data.title} description={data.summary} ogImage={ogImage}>

  <!-- Hero area -->
  <div class="mx-auto max-w-4xl px-6 pt-16 pb-10">

    <!-- Category + year breadcrumb -->
    <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-6">
      <a href="/projects/" class="hover:text-[var(--color-accent)] transition-colors">Projects</a>
      <span class="mx-2">·</span>
      <span class="capitalize">{data.category}</span>
      <span class="mx-2">·</span>
      <span>{data.startDate!.getFullYear()}</span>
    </p>

    <!-- Title -->
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight text-[var(--color-text)] mb-4 leading-tight">
      {data.title}
    </h1>

    <!-- One-line summary -->
    <p class="text-lg text-[var(--color-text-muted)] mb-8 max-w-2xl leading-relaxed">
      {data.summary}
    </p>

    <!-- Meta strip: role / team / year -->
    <dl class="flex flex-wrap gap-x-10 gap-y-3 mb-8 border-t border-b border-[var(--color-border)] py-5">
      <div>
        <dt class="text-[10px] font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-0.5">Role</dt>
        <dd class="text-sm font-medium text-[var(--color-text)]">{data.role}</dd>
      </div>
      {data.teamSize && (
        <div>
          <dt class="text-[10px] font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-0.5">Team</dt>
          <dd class="text-sm font-medium text-[var(--color-text)]">{data.teamSize} members</dd>
        </div>
      )}
      <div>
        <dt class="text-[10px] font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-0.5">Period</dt>
        <dd class="text-sm font-medium text-[var(--color-text)]">{formatDateRange(data.startDate!, data.endDate)}</dd>
      </div>
      <div>
        <dt class="text-[10px] font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-0.5">Duration</dt>
        <dd class="text-sm font-medium text-[var(--color-text)]">{formatDuration(data.startDate!, data.endDate)}</dd>
      </div>
      <div>
        <dt class="text-[10px] font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-0.5">Status</dt>
        <dd>
          {data.status === 'shipped' && (
            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300">Shipped</span>
          )}
          {data.status === 'in-progress' && (
            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300">In Progress</span>
          )}
          {data.status === 'planned' && (
            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300">Planned</span>
          )}
          {data.status === 'archived' && (
            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400">Archived</span>
          )}
        </dd>
      </div>
      <div>
        <dt class="text-[10px] font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-0.5">Category</dt>
        <dd class="text-sm font-medium text-[var(--color-text)] capitalize">{data.category}</dd>
      </div>
    </dl>

    <!-- CTA links: GitHub + live demo -->
    <div class="flex flex-wrap gap-3">
      {data.github && (
        <a
          href={data.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-[var(--color-border)] text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
        >
          GitHub ↗
        </a>
      )}
      {data.liveDemo && (
        <a
          href={data.liveDemo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[var(--color-accent)] text-[var(--color-bg)] text-sm font-semibold hover:bg-[var(--color-accent-hover)] transition-colors"
        >
          Live Demo ↗
        </a>
      )}
    </div>

  </div>

  <!-- Gallery (carousel) — shown when project has media entries -->
  {data.media && data.media.length > 0 && (
    <div class="mx-auto max-w-4xl px-6 pb-10">
      <p class="text-[10px] font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-3">Gallery</p>
      <MediaCarousel media={data.media} client:visible />
    </div>
  )}

  <!-- Tech stack badges -->
  <div class="mx-auto max-w-4xl px-6 pb-10">
    <p class="text-[10px] font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-3">Tech Stack</p>
    <div class="flex flex-wrap gap-2">
      {data.techStack.map((tech) => (
        <span class="px-3 py-1 rounded-full text-xs font-semibold tracking-wide border border-[var(--color-border)] text-[var(--color-text-muted)] bg-[var(--color-bg-subtle)]">
          {tech}
        </span>
      ))}
    </div>
  </div>

  <!-- Case study body -->
  <div class="mx-auto max-w-4xl px-6 pb-10">
    <article class="prose prose-neutral dark:prose-invert max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-headings:text-[var(--color-text)] prose-p:text-[var(--color-text-muted)] prose-p:leading-relaxed prose-li:text-[var(--color-text-muted)] prose-code:font-mono prose-code:text-sm prose-pre:bg-[var(--color-bg-subtle)] prose-pre:rounded-xl prose-pre:p-5 prose-pre:overflow-x-auto prose-blockquote:not-italic prose-blockquote:border-l-4 prose-blockquote:border-[var(--color-accent)] prose-blockquote:bg-[var(--color-bg-subtle)] prose-blockquote:rounded-r-xl prose-blockquote:px-5 prose-blockquote:py-3 prose-blockquote:text-[var(--color-text-muted)] prose-blockquote:text-sm">
      <Content />
    </article>
  </div>

  <!-- In-progress / planned callout -->
  {(data.status === 'in-progress' || data.status === 'planned') && (
    <div class="mx-auto max-w-4xl px-6 pb-10">
      <div class="rounded-xl border border-amber-300 bg-amber-50 dark:border-amber-700 dark:bg-amber-900/20 px-6 py-4">
        <p class="text-sm font-semibold text-amber-800 dark:text-amber-300">
          {data.status === 'in-progress' ? '🚧 This project is currently in progress — content may be incomplete.' : '📋 This project is planned and not yet started.'}
        </p>
      </div>
    </div>
  )}

  <!-- Results — shown for shipped projects only -->
  {data.status === 'shipped' && data.results && data.results.length > 0 && (
    <div class="mx-auto max-w-4xl px-6 pb-10">
      <div class="rounded-xl bg-[var(--color-bg-subtle)] border border-[var(--color-border)] p-6">
        <h2 class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-4">Results</h2>
        <ul class="space-y-2">
          {data.results.map((item) => (
            <li class="flex items-start gap-2 text-sm font-semibold text-[var(--color-text)]">
              <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]" />
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  )}

  <!-- Reflection — shown for shipped and archived projects -->
  {(data.status === 'shipped' || data.status === 'archived') && data.reflection && (
    <div class="mx-auto max-w-4xl px-6 pb-10">
      <div class="border-l-2 border-[var(--color-accent)] pl-6 py-1">
        <h2 class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-4">Reflection</h2>
        {data.reflection.split('\n\n').map((para) => (
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4 last:mb-0">{para}</p>
        ))}
      </div>
    </div>
  )}

  <!-- Back nav -->
  <div class="mx-auto max-w-4xl px-6 pb-10 border-t border-[var(--color-border)] pt-8">
    <a
      href="/projects/"
      class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
    >
      ← All projects
    </a>
  </div>

  <FooterCTA />

</BaseLayout>
