---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FooterCTA from '../../components/FooterCTA.astro';
import ProjectFilter from '../../components/ProjectFilter';
import type { ProjectFilterItem } from '../../lib/filter';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const projects: ProjectFilterItem[] = await Promise.all(
  sorted.map(async (project) => {
    let thumbnail: ProjectFilterItem['thumbnail'] = null;
    if (project.data.thumbnail) {
      const img = await getImage({
        src: project.data.thumbnail,
        width: 800,
        height: 450,
        format: 'webp',
      });
      thumbnail = { src: img.src, width: 800, height: 450, format: 'webp' };
    }
    return {
      id: project.id,
      title: project.data.title,
      summary: project.data.summary,
      tags: project.data.tags,
      groups: project.data.groups ?? [],
      sortOrder: project.data.sortOrder,
      startYear: project.data.startDate.getFullYear(),
      status: project.data.status,
      href: `/projects/${project.id}/`,
      thumbnail,
    };
  }),
);
---

<BaseLayout
  title="Projects"
  description="Software engineering projects by Zain Altaf: hackathon builds, trading bots, accessible-tech applications, and more."
>

  <div class="mx-auto max-w-5xl px-6 pt-16 pb-10">

    <!-- Page header -->
    <div class="mb-10">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold leading-tight tracking-tight text-text">Projects</h1>
    </div>

    <!-- Filter + project grid (React island) -->
    <ProjectFilter client:load projects={projects} />

  </div>

  <FooterCTA />

</BaseLayout>
