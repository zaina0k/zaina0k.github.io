---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Zain Altaf — CS graduate and software engineer.">
  <div class="mx-auto max-w-5xl px-6 py-20">

    <!-- Status badge -->
    <div class="flex items-center gap-2 mb-8">
      <span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
      <span class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)]">
        CS Graduate · Open to opportunities
      </span>
    </div>

    <!-- Heading -->
    <h1 class="text-4xl md:text-5xl font-semibold leading-tight tracking-tight text-[var(--color-text)] mb-10">
      Zain Altaf
    </h1>

    <!-- Bio paragraphs -->
    <div class="max-w-2xl space-y-5 text-[var(--color-text-muted)] leading-relaxed">
      <p>
        I'm a Computer Science graduate from the University of Leicester, where I built
        a foundation across algorithms, systems, and software design. I wrote my first
        line of code to automate something tedious, and that instinct — build it rather
        than endure it — has stuck.
      </p>
      <p>
        I work primarily with Python and JavaScript, and I'm comfortable across the
        stack: REST APIs, database design, front-end interfaces, and the deployment
        pipelines that tie them together. My projects tend toward tools with real users
        — things that needed to exist and didn't yet.
      </p>
      <p>
        I'm looking for my first full-time software engineering role and open to
        conversations about engineering, collaboration, and interesting problems.
        If something you're building sounds like a good fit, I'd like to hear about it.
      </p>
    </div>

    <!-- Social links -->
    <div class="flex flex-wrap items-center gap-6 mt-10 pt-10 border-t border-[var(--color-border)]">
      <a
        href="mailto:dev@zainaltaf.com"
        class="inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
      >
        dev@zainaltaf.com →
      </a>
      <a
        href="https://linkedin.com/in/zainaltaf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        LinkedIn ↗
      </a>
      <a
        href="https://github.com/zainaltaf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        GitHub ↗
      </a>
    </div>

  </div>
</BaseLayout>
