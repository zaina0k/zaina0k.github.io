---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import FooterCTA from '../components/FooterCTA.astro';
import profileImg from '../assets/profile.png';

const skillRows = [
  { category: 'Languages',   skills: ['Python', 'JavaScript', 'TypeScript', 'C#', 'SQL', 'HTML', 'CSS'] },
  { category: 'Frameworks',  skills: ['Next.js', 'Flask', 'React', 'Unity'] },
  { category: 'Tools',       skills: ['Git', 'GitHub', 'REST APIs', 'SQLite', 'VS Code'] },
  { category: 'Concepts',    skills: ['Algorithms', 'Data Structures', 'API Design', 'Agile', 'TDD'] },
];
---

<BaseLayout title="About" description="About Zain Altaf — Computer Science graduate from the University of Leicester, building full-stack web applications.">
  <div class="mx-auto max-w-5xl px-6 py-20">

    <!-- Bio header: two-column on md+ (text left, photo right) -->
    <div class="flex flex-col md:flex-row md:items-start md:gap-16">

      <!-- Left: status, heading, bio -->
      <div class="flex-1">
        <!-- Status badge -->
        <div class="flex items-center gap-2 mb-8">
          <span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          <span class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)]">
            CS Graduate · Open to opportunities
          </span>
        </div>

        <!-- Heading -->
        <h1 class="text-4xl md:text-5xl font-semibold leading-tight tracking-tight text-[var(--color-text)] mb-10">
          Zain Altaf
        </h1>

        <!-- Bio paragraphs -->
        <div class="space-y-5 text-[var(--color-text-muted)] leading-relaxed">
          <p>
            I'm a Computer Science graduate from the University of Leicester, where I built
            a foundation across algorithms, systems, and software design. I wrote my first
            line of code to automate something tedious, and that instinct — build it rather
            than endure it — has stuck.
          </p>
          <p>
            I work primarily with Python and JavaScript, and I'm comfortable across the
            stack: REST APIs, database design, front-end interfaces, and the deployment
            pipelines that tie them together. My projects tend toward tools with real users
            — things that needed to exist and didn't yet.
          </p>
          <p>
            I'm looking for my first full-time software engineering role and open to
            conversations about engineering, collaboration, and interesting problems.
            If something you're building sounds like a good fit, I'd like to hear about it.
          </p>
        </div>
      </div>

      <!-- Right: profile photo -->
      <div class="shrink-0 order-first md:order-last mb-8 md:mb-0">
        <Image
          src={profileImg}
          alt="Zain Altaf"
          width={256}
          height={256}
          densities={[1, 2, 3]}
          class="w-48 h-48 md:w-64 md:h-64 rounded-xl object-cover border border-[var(--color-border)]"
        />
      </div>

    </div>

    <!-- Skills grid -->
    <div class="mt-16">
      <div class="flex items-baseline gap-4 mb-8">
        <span class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)]">Skills</span>
        <h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)]">What I Work With</h2>
      </div>
      <div class="flex flex-col divide-y divide-[var(--color-border)]">
        {skillRows.map(({ category, skills }) => (
          <div class="flex flex-col sm:flex-row sm:items-baseline gap-3 sm:gap-8 py-5">
            <span class="w-28 shrink-0 text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)]">
              {category}
            </span>
            <div class="flex flex-wrap gap-x-4 gap-y-2">
              {skills.map((skill) => (
                <span class="text-sm text-[var(--color-text)]">{skill}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Education + milestones timeline -->
    <div class="mt-16">
      <div class="flex items-baseline gap-4 mb-8">
        <span class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)]">Timeline</span>
        <h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)]">Education & Milestones</h2>
      </div>

      <div class="relative flex flex-col gap-0">
        <!-- Vertical rule -->
        <div class="absolute left-[7px] top-2 bottom-2 w-px bg-[var(--color-border)]"></div>

        <!-- University of Leicester -->
        <div class="relative flex gap-6 pb-10">
          <div class="mt-1.5 w-4 h-4 shrink-0 rounded-full border-2 border-[var(--color-accent)] bg-[var(--color-bg)]"></div>
          <div>
            <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-1">2022 – 2025</p>
            <h3 class="text-base font-semibold text-[var(--color-text)]">University of Leicester</h3>
            <p class="text-sm text-[var(--color-text-muted)] mt-0.5">BSc Computer Science — graduated 2025</p>
          </div>
        </div>

        <!-- Let's Hack Leicester -->
        <div class="relative flex gap-6 pb-10">
          <div class="mt-1.5 w-4 h-4 shrink-0 rounded-full border-2 border-[var(--color-border)] bg-[var(--color-bg)]"></div>
          <div>
            <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-1">2024</p>
            <h3 class="text-base font-semibold text-[var(--color-text)]">Let's Hack Leicester</h3>
            <p class="text-sm text-[var(--color-text-muted)] mt-0.5">
              Led a team of 5 to build a full-stack collaborative platform in 24 hours.
              Next.js, Flask, SQLite. Capital One–sponsored hackathon.
            </p>
          </div>
        </div>

        <!-- Morgan Stanley Coding Challenge -->
        <div class="relative flex gap-6 pb-10">
          <div class="mt-1.5 w-4 h-4 shrink-0 rounded-full border-2 border-[var(--color-border)] bg-[var(--color-bg)]"></div>
          <div>
            <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-1">2024</p>
            <h3 class="text-base font-semibold text-[var(--color-text)]">Morgan Stanley Coding Challenge</h3>
            <p class="text-sm text-[var(--color-text-muted)] mt-0.5">
              Built an EMA-based algorithmic trading bot. Placed 7th out of 27 teams.
            </p>
          </div>
        </div>

        <!-- Graduation -->
        <div class="relative flex gap-6">
          <div class="mt-1.5 w-4 h-4 shrink-0 rounded-full border-2 border-[var(--color-accent)] bg-[var(--color-accent)]"></div>
          <div>
            <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mb-1">2025</p>
            <h3 class="text-base font-semibold text-[var(--color-text)]">Graduated — open to opportunities</h3>
            <p class="text-sm text-[var(--color-text-muted)] mt-0.5">
              Now looking for a first software engineering role.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA + social links -->
    <div class="mt-16 pt-10 border-t border-[var(--color-border)]">
      <!-- Primary CTAs -->
      <div class="flex flex-wrap gap-3 mb-8">
        <a
          href="/cv"
          download
          class="inline-flex items-center px-5 py-2.5 rounded text-sm font-semibold bg-[var(--color-accent)] text-[var(--color-bg)] hover:bg-[var(--color-accent-hover)] transition-colors"
        >
          Download CV ↗
        </a>
        <a
          href="/contact"
          class="inline-flex items-center px-5 py-2.5 rounded text-sm font-semibold border border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
        >
          Get in touch →
        </a>
      </div>

      <!-- Social links -->
      <div class="flex flex-wrap items-center gap-6">
        <a
          href="mailto:dev@zainaltaf.com"
          class="inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
        >
          dev@zainaltaf.com →
        </a>
        <a
          href="https://www.linkedin.com/in/m-z-altaf/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
        >
          LinkedIn ↗
        </a>
        <a
          href="https://github.com/zaina0k"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
        >
          GitHub ↗
        </a>
      </div>
    </div>

  </div>
  <FooterCTA />
</BaseLayout>
