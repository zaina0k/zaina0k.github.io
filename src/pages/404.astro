---
import BaseLayout from '../layouts/BaseLayout.astro';
import { UI_IMAGES } from '../lib/images';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="mx-auto max-w-5xl px-6 py-32 text-center">
    <img src={UI_IMAGES.errorPage} alt="" aria-hidden="true" width={320} height={320} class="w-48 h-auto mx-auto mb-8 opacity-80" />
    <p class="text-sm font-mono text-[var(--color-accent)] mb-4 tracking-widest uppercase">404</p>
    <h1 class="text-4xl sm:text-5xl font-semibold leading-tight tracking-tight text-[var(--color-text)] mb-6">
      Page not found.
    </h1>
    <p class="text-[var(--color-text-muted)] text-lg mb-10 max-w-md mx-auto">
      This URL doesn't exist on the new site. The projects index has everything worth finding.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="inline-block px-6 py-3 bg-[var(--color-accent)] text-white font-medium rounded-lg hover:opacity-90 transition-opacity">
        Go home
      </a>
      <a href="/projects/" class="inline-block px-6 py-3 border border-[var(--color-border)] text-[var(--color-text)] font-medium rounded-lg hover:bg-[var(--color-surface)] transition-colors">
        Browse projects
      </a>
    </div>
  </div>
</BaseLayout>
